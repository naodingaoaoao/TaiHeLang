# 太和编程语言示例 - Hello World
# 这是一个简单的Hello World程序

函数 主():
    # 输出欢迎信息
    输出("你好，太和编程语言！")
    
    # 基本运算
    变量 x = 10
    变量 y = 20
    变量 和 = x + y
    
    输出("x + y = " + 和)
    
    # 条件语句
    如果 和 > 0:
        输出("和是正数")
    否则:
        输出("和是非正数")
    
    # 循环
    变量 计数器 = 0
    当 计数器 < 3:
        输出("循环计数:" + 计数器)
        计数器 = 计数器 + 1
    
    # 返回0表示成功
    返回 0